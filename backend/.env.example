# Required Environment Variables for Backend
# Copy this file and rename it to .env
# Fill in your actual values — never commit the real .env file to GitHub

NODE_ENV=development
PORT=5000

# MongoDB connection string
# For local development use: mongodb://127.0.0.1:27017/student-note-books
MONGO_URI=your_mongodb_connection_string

# JWT secret — use any long random string
JWT_SECRET=your_jwt_secret_key

# Cloudinary — for product image uploads (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay — for payment processing (https://razorpay.com)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
